    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@reqly/types": "workspace:*",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
