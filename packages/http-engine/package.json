{
  "name": "@reqly/http-engine",
  "version": "0.1.0",
  "description": "HTTP request engine with variable interpolation and scripting support",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
