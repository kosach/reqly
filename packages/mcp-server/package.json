{
  "name": "@reqly/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Reqly",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "reqly-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --testPathPattern=index.test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@reqly/types": "workspace:*",
    "@reqly/database": "workspace:*",
    "@reqly/http-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
